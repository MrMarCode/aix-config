  "mcp": {
    "aws-knowledge-mcp": {
      "url": "https://knowledge-mcp.global.api.aws"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ]
    },
    "libragen": {
      "command": "npx",
      "args": [
        "-y",
        "@libragen/mcp"
      ],
      "enabled": false
    },

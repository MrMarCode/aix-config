{
   "$schema": "https://x.a1st.dev/schemas/v1/ai.json",
   "skills": {
      "hypothesis-tree": {
         "git": "https://github.com/flpbalada/thinking-toolkit",
         "ref": "main",
         "path": "plugins/hypothesis-tree/skills/hypothesis-tree"
      },
      "user-story-fundamentals": {
         "git": "https://github.com/flpbalada/thinking-toolkit",
         "ref": "main",
         "path": "plugins/user-story-fundamentals/skills/user-story-fundamentals"
      },
      "five-whys": {
         "git": "https://github.com/flpbalada/thinking-toolkit",
         "ref": "main",
         "path": "plugins/five-whys/skills/five-whys"
      },
      "graph-thinking": {
         "git": "https://github.com/flpbalada/thinking-toolkit",
         "ref": "main",
         "path": "plugins/graph-thinking/skills/graph-thinking"
      },
      "git": {
         "path": "./skills/git/"
      },
      "worktree": {
         "path": "./skills/worktree"
      }
   },
   "mcp": {
      "aws-knowledge-mcp": {
         "url": "https://knowledge-mcp.global.api.aws"
      },
      "context7": {
         "command": "npx",
         "args": [
            "-y",
            "@upstash/context7-mcp"
         ]
      },
      "git": {
         "command": "uvx",
         "args": [
            "mcp-server-git"
         ]
      },
      "libragen": {
         "command": "npx",
         "args": [
            "-y",
            "@libragen/mcp"
         ],
         "enabled": false
      },
      "run-box": {
         "url": "http://127.0.0.1:3100/mcp"
      },
      "@hypothesi/tauri-mcp-server": {
         "command": "npx",
         "args": [
            "@hypothesi/tauri-mcp-server"
         ]
      },
      "mcp-playwright": {
         "args": [
         "-y",
         "@playwright/mcp@latest"
         ],
         "command": "npx"
      },
      "custom-gitlab": {
         "url": "http://localhost:3015/mcp"
      },
      "nixos": {
         "args": [
         "run",
         "--rm",
         "-i",
         "ghcr.io/utensils/mcp-nixos"
         ],
         "command": "docker"
      }
   },
   "rules": {
      "general": "./rules/general.md",
      "comments": "./rules/comments.md",
      "control-flow": "./rules/control-flow.md",
      "formatting": "./rules/formatting.md",
      "git": "./rules/git.md",
      "logging-error-handling": "./rules/logging-error-handling.md",
      "naming-conventions": "./rules/naming-conventions.md",
      "npm": "./rules/npm.md",
      "shell": "./rules/shell.md",
      "testing": "./rules/testing.md",
      "typescript": "./rules/typescript.md",
      "writing": "./rules/writing.md",
      "yaml": "./rules/yaml.md",
      "rust": "./rules/rust.md",
      "vue": "./rules/vue.md",
      "mcps": "./rules/mcps.md",
      "tauri": "./rules/tauri.md"
   },
   "prompts": {
      "aws-advice": "./prompts/aws-advice.md",
      "command": "./prompts/command.md",
      "create-dynamo-table-workflow": "./prompts/create-dynamo-table-workflow.md",
      "create-tool": "./prompts/create-tool.md",
      "debug": "./prompts/debug.md",
      "lessons-learned": "./prompts/lessons-learned.md",
      "prime-context": "./prompts/prime-context.md",
      "prompt-engineer": "./prompts/prompt-engineer.md",
      "review-changes": "./prompts/review-changes.md",
      "say": "./prompts/say.md",
      "test-a-library": "./prompts/test-a-library.md",
      "test-driven-development": "./prompts/test-driven-development.md",
      "task-loop": "./prompts/task-loop.md"
   }
}
